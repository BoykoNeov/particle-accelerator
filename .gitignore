# Virtual environments
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.so

# xtrack/cffi JIT C-kernel build artifacts (Windows clang-cl/MSVC intermediates,
# emitted into the CWD by xobjects' compile and not auto-cleaned on Windows)
Release/
*.obj
*.exp
*.lib
*.pyd

# Testing / coverage
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Tooling caches
.mypy_cache/

# Generated figures / scratch output
output/
*.png
!docs/**/*.png

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# xtrack JIT-kernel spills: 32-hex-char C sources dropped in the repo root (CWD)
# on first kernel compile. Anchored to root and pure-Python repo, so this can't
# hide a real source file; the glob is still broader than "hex-only 32 chars"
# (globs lack quantifiers), which is harmless here since the repo has no .c files.
/[0-9a-f]*.c
